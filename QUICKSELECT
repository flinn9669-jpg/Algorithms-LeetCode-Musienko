import random
def partition(arr, low, high):
    pivot = arr[high]
    i = low - 1
    for j in range(low, high):
        if arr[j] < pivot:
            i += 1
            arr[i], arr[j] = arr[j], arr[i]
    arr[i + 1], arr[high] = arr[high], arr[i + 1]
    return i + 1
def quick_select(arr, k):
    #возвращает k-й наименьший элемент массива (k начинается с 0)
    #массив изменяется (inplace), но полностью не сортируется
    if k < 0 or k >= len(arr):
        raise IndexError("k выходит за границы массива")
    low = 0
    high = len(arr) - 1
    while low <= high:
        random_index = random.randint(low, high)
        arr[random_index], arr[high] = arr[high], arr[random_index]
        pivot_index = partition(arr, low, high)
        #если pivot оказался ровно на позиции k, то
        #значит это и есть k-й наименьший элемент
        if pivot_index == k:
            return arr[pivot_index]
        #если k меньше позиции pivot, то
        #продолжает искать только в левой части
        elif k < pivot_index:
            high = pivot_index - 1
        #если k больше, то
        #ищет только в правой части
        else:
            low = pivot_index + 1
            
            
#пример использования
if __name__ == "__main__":
    arr = [14, 9, 1, 6, 2, 5]
    k = 3  #3-й наименьший (нумерация с 0)
    result = quick_select(arr, k)
    print(f"{k}-й наименьший элемент:", result)
